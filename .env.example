# Database
DB_NAME=gamedev_db
DB_USER=gamedev_user
DB_PASSWORD=your-secure-password
# DB_HOST depends on where the process runs:
#   localhost  -> `cd backend && pytest` or manage.py on the host
#   db         -> inside Docker Compose (docker-compose.yml already sets this
#                 explicitly for the backend service, so this value only
#                 matters for host-run commands)
DB_HOST=localhost
DB_PORT=5432

# PRODUCTION ONLY — leave unset for local dev.
# When set, this wins over every DB_* value above and is parsed with
# SSL required + connection reuse (Neon). Unset locally = DB_* is used.
# DATABASE_URL=postgresql://user:password@host/dbname

# Django
SECRET_KEY=your-secret-key-here-change-in-production
# DEBUG now defaults to False when unset. Local dev must set it explicitly,
# otherwise settings.py raises ImproperlyConfigured for the insecure
# SECRET_KEY default.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Public self-registration is OFF by default (the live site is a shared demo).
# Enable it for local development if you want the /register flow / seeded users
# to be able to sign up. Leave unset/false in production.
# ALLOW_REGISTRATION=True
# Throttle anonymous requests by IP (brute-force guard). Unset = unlimited
# (fine locally). Production sets this, e.g. 30/min.
# THROTTLE_ANON=30/min
# Move the Django admin off the default /admin/ path in production. No leading
# slash; must end with '/'. Defaults to 'admin/' when unset.
# ADMIN_URL=admin/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PRODUCTION ONLY — leave unset for local dev.
# Turns on SSL redirect, secure cookies, HSTS, and the X-Forwarded-Proto
# header Render needs. Setting this locally will break http://localhost.
# USE_HTTPS=True

# PRODUCTION ONLY — leave unset for local dev.
# Origins allowed to POST to /admin/ and any session-authenticated endpoint.
# Must include the scheme.
# CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com

# PRODUCTION ONLY — leave unset for local dev (compose keeps FileSystemStorage).
# Cloudflare R2 media storage. When USE_R2=True, ALL five R2_* vars below are
# required — a missing one fails at boot by design. R2_PUBLIC_HOST is the
# public r2.dev dev-subdomain host, no scheme (e.g. pub-abc123.r2.dev).
# USE_R2=True
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET_NAME=stemquest-media
# R2_PUBLIC_HOST=pub-abc123.r2.dev

# ===========================================
# Email Configuration
# ===========================================

# For development (emails print to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=STEM Quest <noreply@yourdomain.com>

# Gmail App Password Setup:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Use the 16-character password as EMAIL_HOST_PASSWORD

# Alternative: SendGrid (recommended for production)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Email verification (optional for dev, mandatory for prod)
ACCOUNT_EMAIL_VERIFICATION=optional

# Frontend URL (used for links in emails). Defaults to the localhost value
# below if unset, which is why local dev works without it; production must
# set it to the real site URL or emailed links point at localhost.
FRONTEND_URL=http://localhost:5173

# Sentry (optional for dev)
SENTRY_DSN=

# Redis (Phase 5)
REDIS_URL=redis://localhost:6379/0

# Frontend URLs
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# Frontend Sentry (optional for dev)
VITE_SENTRY_DSN=
