# Database
DB_NAME=gamedev_db
DB_USER=gamedev_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# Email Configuration
# ===========================================

# For development (emails print to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=GameDev Platform <noreply@yourdomain.com>

# Gmail App Password Setup:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and your device
# 4. Use the 16-character password as EMAIL_HOST_PASSWORD

# Alternative: SendGrid (recommended for production)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Email verification (optional for dev, mandatory for prod)
ACCOUNT_EMAIL_VERIFICATION=optional

# Frontend URL (used for links in emails)
FRONTEND_URL=http://localhost:5173

# Sentry (optional for dev)
SENTRY_DSN=

# Redis (Phase 5)
REDIS_URL=redis://localhost:6379/0

# Frontend URLs
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# Frontend Sentry (optional for dev)
VITE_SENTRY_DSN=
