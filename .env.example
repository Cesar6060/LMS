# Database
DB_NAME=gamedev_db
DB_USER=gamedev_user
DB_PASSWORD=your-secure-password
# DB_HOST depends on where the process runs:
#   localhost  -> `cd backend && pytest` or manage.py on the host
#   db         -> inside Docker Compose (docker-compose.yml already sets this
#                 explicitly for the backend service, so this value only
#                 matters for host-run commands)
DB_HOST=localhost
DB_PORT=5432

# PRODUCTION ONLY — leave unset for local dev.
# When set, this wins over every DB_* value above and is parsed with
# SSL required + connection reuse (Neon). Unset locally = DB_* is used.
# DATABASE_URL=postgresql://user:password@host/dbname

# Django
SECRET_KEY=your-secret-key-here-change-in-production
# DEBUG now defaults to False when unset. Local dev must set it explicitly,
# otherwise settings.py raises ImproperlyConfigured for the insecure
# SECRET_KEY default.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Public self-registration is OFF by default (the live site is a shared demo).
# Enable it for local development if you want the /register flow / seeded users
# to be able to sign up. Leave unset/false in production.
# ALLOW_REGISTRATION=True
# Throttle anonymous requests by IP (brute-force guard). Unset = unlimited
# (fine locally). Production sets this, e.g. 30/min.
# THROTTLE_ANON=30/min
# Throttle the one-click demo login (POST /api/auth/demo-login/) by IP.
# Unset = unlimited (fine locally). Production sets this in the Render
# dashboard (the single source of truth for prod env vars since Phase 48).
# THROTTLE_DEMO_LOGIN=10/min
# Password seed_demo_account assigns to the shared demo account. Defaults to
# Admin123! so local dev and tests need no setup; production sets a generated
# secret (and re-runs seed_demo_account) so visitors can only enter through
# the demo-login endpoint, never with raw credentials.
# DEMO_ACCOUNT_PASSWORD=Admin123!
# Move the Django admin off the default /admin/ path in production. No leading
# slash; must end with '/'. Defaults to 'admin/' when unset.
# ADMIN_URL=admin/
# Throttle authenticated traffic per user id (Phase 51 — real students).
# Unset = unlimited (fine locally). Production sets e.g. 120/min.
# THROTTLE_USER=120/min
# Scoped rates for the invite endpoints (Phase 51). Unset = unlimited.
# Sending is instructor-triggered email; accepting is anonymous account
# creation, so it gets the tighter rate.
# THROTTLE_INVITE_SEND=30/hour
# THROTTLE_INVITE_ACCEPT=10/hour

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PRODUCTION ONLY — leave unset for local dev.
# Turns on SSL redirect, secure cookies, HSTS, and the X-Forwarded-Proto
# header Render needs. Setting this locally will break http://localhost.
# USE_HTTPS=True

# PRODUCTION ONLY — leave unset for local dev.
# Origins allowed to POST to /admin/ and any session-authenticated endpoint.
# Must include the scheme.
# CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com

# PRODUCTION ONLY — leave unset for local dev (compose keeps FileSystemStorage).
# Cloudflare R2 media storage. When USE_R2=True, ALL four R2_* credential vars
# below are required — a missing one fails at boot by design. The bucket is
# private: objects are served via presigned URLs that expire after
# R2_SIGNED_URL_TTL seconds (optional, default 3600).
# USE_R2=True
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET_NAME=stemquest-media
# R2_SIGNED_URL_TTL=3600

# ===========================================
# Email Configuration
# ===========================================

# For development (emails print to console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production, use SMTP on a transactional provider with the user's own
# domain (Phase 51 — Resend replaces the Phase 47 personal Gmail; all of it,
# literals and credentials alike, is set in the Render dashboard — Phase 48).
# See docs/runbooks/phase-51-email-provider-steps.txt for DNS + provider setup.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=your-resend-api-key
# DEFAULT_FROM_EMAIL=STEM Quest <noreply@your-domain.com>
# Seconds before a stuck SMTP connection is abandoned (default 10):
# EMAIL_TIMEOUT=10
# Per-IP rate for the anonymous password-reset endpoint (unset = unlimited;
# production uses 5/hour):
# THROTTLE_PASSWORD_RESET=5/hour

# Email verification ('optional' everywhere, including prod — registration is
# disabled on the live demo, so mandatory verification has nothing to gate)
ACCOUNT_EMAIL_VERIFICATION=optional

# Frontend URL (used for links in emails). Defaults to the localhost value
# below if unset, which is why local dev works without it; production must
# set it to the real site URL or emailed links point at localhost.
FRONTEND_URL=http://localhost:5173

# Sentry (optional for dev)
SENTRY_DSN=

# Redis (Phase 5)
REDIS_URL=redis://localhost:6379/0

# Frontend URLs
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws

# Frontend Sentry (optional for dev)
VITE_SENTRY_DSN=
